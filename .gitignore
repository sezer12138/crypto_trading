# =====================================================
# crypto_trading - .gitignore
# =====================================================

# --- OS / Editor metadata ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Hidden directories (.claude/, .vscode/, .idea/, .pytest_cache/,
#     .venv/, .tox/, .ipynb_checkpoints/, .eggs/, etc.) ---
.*/

# --- Python build / packaging ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.Python
.installed.cfg
build/
develop-eggs/
dist/
downloads/
eggs/
parts/
sdist/
wheels/
lib/
lib64/
var/

# --- Virtual environments (non-hidden names) ---
venv/
env/
ENV/

# --- Environment / secrets ---
.env
.env.local
config/.env

# --- Logs / Results / Coverage ---
logs/
results/
htmlcov/
.coverage

# --- Data files (raw inputs are not committed) ---
data/raw/*.csv
data/raw/*.json
data/processed/*.csv
data/processed/*.json
data/historical/*.csv
data/historical/*.json

# --- Temporary files ---
tmp/
temp/
*.tmp

# --- Project-specific ---
CLAUDE.md
docs/
optimization_tasks.json
